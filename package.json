{
  "publisher": "frankie",
  "name": "github-blogger",
  "displayName": "GitHub Blogger",
  "version": "2.6.0",
  "packageManager": "pnpm@10.28.0",
  "description": "Write and manage blog posts via GitHub issues",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/github-blogger",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/github-blogger.git"
  },
  "bugs": {
    "url": "https://github.com/tofrankie/github-blogger/issues",
    "email": "1426203851@qq.com"
  },
  "keywords": [
    "github",
    "blogger",
    "blog",
    "vscode"
  ],
  "categories": [
    "Notebooks"
  ],
  "main": "./dist/extension/index.js",
  "icon": "./images/icon.png",
  "engines": {
    "vscode": "^1.88.0"
  },
  "l10n": "./l10n",
  "activationEvents": [],
  "contributes": {
    "configuration": {
      "title": "GitHub Blogger",
      "properties": {
        "github-blogger.token": {
          "type": "string",
          "description": "%github-blogger.configuration.token.description%",
          "default": ""
        },
        "github-blogger.user": {
          "type": "string",
          "description": "%github-blogger.configuration.user.description%",
          "default": ""
        },
        "github-blogger.repo": {
          "type": "string",
          "description": "%github-blogger.configuration.repo.description%",
          "default": ""
        },
        "github-blogger.branch": {
          "type": "string",
          "description": "%github-blogger.configuration.branch.description%",
          "default": "main"
        }
      }
    },
    "commands": [
      {
        "command": "github-blogger.open",
        "title": "%github-blogger.command.open%"
      },
      {
        "command": "github-blogger.configure",
        "title": "%github-blogger.command.configure%"
      }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "vsce package --no-dependencies",
    "package:pre": "vsce package --pre-release --no-dependencies",
    "prepackage": "pnpm build",
    "prepackage:pre": "pnpm build",
    "ext:publish": "vsxpub --no-dependencies --exclude git",
    "lint": "run-s lint:eslint lint:prettier lint:stylelint typecheck",
    "lint:eslint": "eslint . --cache --fix",
    "lint:prettier": "prettier . --cache --write --log-level silent",
    "lint:stylelint": "stylelint './**/*.{css,html}' --cache --fix",
    "typecheck": "tsc --noEmit",
    "check": "run-s typecheck lint",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@bytemd/plugin-breaks": "1.22.0",
    "@bytemd/plugin-frontmatter": "1.22.0",
    "@bytemd/plugin-gemoji": "1.22.0",
    "@bytemd/plugin-gfm": "1.22.0",
    "@bytemd/plugin-highlight": "1.22.0",
    "@bytemd/plugin-math": "1.22.0",
    "@bytemd/plugin-medium-zoom": "1.22.0",
    "@bytemd/plugin-mermaid": "1.22.0",
    "@bytemd/react": "1.22.0",
    "@octokit/core": "7.0.6",
    "@primer/css": "22.2.0",
    "@primer/octicons-react": "19.28.0",
    "@primer/primitives": "11.9.0",
    "@primer/react": "38.26.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-query-devtools": "5.100.14",
    "@vscode/webview-ui-toolkit": "1.4.0",
    "buffer": "6.0.3",
    "bytemd": "1.22.0",
    "core-js": "3.49.0",
    "dayjs": "1.11.21",
    "github-markdown-css": "5.9.0",
    "gray-matter": "4.0.3",
    "highlight.js": "11.11.1",
    "js-base64": "3.7.8",
    "katex": "0.17.0",
    "licia": "1.48.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vscode-webview-rpc": "0.0.4",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@octokit/request-error": "7.1.0",
    "@octokit/types": "16.0.0",
    "@tanstack/eslint-plugin-query": "5.100.14",
    "@tofrankie/commitlint": "0.0.6",
    "@tofrankie/eslint": "0.3.1",
    "@tofrankie/prettier": "0.2.0",
    "@tofrankie/stylelint": "0.3.0",
    "@tofrankie/tsconfig": "0.1.2",
    "@tomjs/vite-plugin-vscode": "7.1.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "1.88.0",
    "@types/vscode-webview": "1.57.5",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vscode/vsce": "3.9.1",
    "eslint": "10.4.1",
    "lint-staged": "16.4.0",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "stylelint": "17.12.0",
    "typescript": "5.9.3",
    "vite": "8.0.14",
    "vsxpub": "0.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  }
}
