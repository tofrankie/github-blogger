{
  "extends": "@tofrankie/tsconfig/react.vite.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./shared/*"]
    },
    "types": ["vite/client", "vscode-webview"]
  },
  "include": ["src", "shared"]
}
